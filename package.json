{
  "name": "rubi-extension",
  "description": "Rubi (ルビ) — AI 日语振假名注音与语境翻译浏览器扩展",
  "version": "0.1.0",
  "license": "GPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ousinki/rubi-extension.git"
  },
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
